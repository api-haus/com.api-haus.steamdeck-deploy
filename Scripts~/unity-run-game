#!/usr/bin/env python3
"""Launch a registered devkit game via the Steam client IPC."""

import argparse
import json
import logging
import os
import subprocess
import sys
import tempfile
import time
from urllib.parse import quote_plus

sys.path.insert(1, os.path.expanduser('~/devkit-utils'))
import devkit_utils

logging.basicConfig(format='%(message)s', level=logging.INFO)
logger = logging.getLogger(__name__)

def main():
    parser = argparse.ArgumentParser(description='Run a devkit game on Steam Deck')
    parser.add_argument('--parms', required=True, help='JSON with gameid and optional settings')
    conf = parser.parse_args()

    parms = json.loads(conf.parms)
    gameid = parms['gameid']

    logger.info('Updating settings for %s', gameid)
    devkit_utils.save_settings(gameid, parms)

    try:
        devkit_utils.validate_steam_client()
    except devkit_utils.SteamClientNotRunningException:
        logger.error('Steam client is not running')
        print(json.dumps({'error': 'Steam client is not running'}))
        sys.exit(1)

    # Kill any previously running instance of the game.
    # Use pgrep to find matching PIDs, excluding our own process tree.
    own_pid = str(os.getpid())
    pgrep = subprocess.run(
        ['pgrep', '-f', gameid],
        capture_output=True, text=True,
    )
    if pgrep.returncode == 0:
        pids = [p for p in pgrep.stdout.strip().split('\n') if p != own_pid]
        if pids:
            logger.info('Killing previous instance of %s (pids: %s)', gameid, ','.join(pids))
            subprocess.run(['kill', '-9'] + pids, capture_output=True)
            time.sleep(2)
        else:
            logger.info('No previous instance running')
    else:
        logger.info('No previous instance running')

    with tempfile.TemporaryDirectory(prefix='unity-run-') as tmpdir:
        response_path = os.path.join(tmpdir, 'response')
        cmd = 'run-game?response={}&gameid={}'.format(
            quote_plus(response_path),
            gameid,
        )
        logger.info('Sending run-game command for %s', gameid)
        devkit_utils.execute_steam_client_command(cmd)

        try:
            with devkit_utils.wait_on_file_response(response_path) as resp:
                print(json.dumps({'success': resp}))
        except devkit_utils.SteamResponse_Timeout:
            print(json.dumps({'error': 'timeout waiting for Steam client response'}))
            sys.exit(1)
        except devkit_utils.SteamResponse_Error as e:
            print(json.dumps({'error': e.error_response}))
            sys.exit(1)

if __name__ == '__main__':
    main()
